# ─────────────────────────────────────────────────────────────
#  CardClash — client environment variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Anakin API (REQUIRED for live card data) ──────────────────
# Get your key at https://anakin.ai
# Used server-side by the Vite dev middleware (/api/squad).
# The key is NEVER shipped to the browser.
# Without this key the app falls back to the bundled demo pack
# (cards still work, but stats/memes won't update live).
ANAKIN_API_KEY=your_anakin_api_key_here

# ── On-chain identity (optional) ──────────────────────────────
# Deploy contracts/CardClashIdentity.sol to Ethereum Sepolia,
# then paste the address here to enable on-chain usernames.
# If left blank, wallet address is used as the display name.
VITE_IDENTITY_ADDRESS=
