# Copy to .env and fill in after deploying the contract.

# Address of CardClashIdentity on Sepolia (from `forge script` output).
# Until set, login still works (wallet = id) but username registration is disabled.
VITE_IDENTITY_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: a more reliable Sepolia RPC (Alchemy/Infura). Falls back to a public one.
VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org
