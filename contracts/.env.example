# Copy to .env before deploying. NEVER commit the real .env.

# A funded Sepolia private key (use a throwaway dev wallet, not your main one).
PRIVATE_KEY=0xyour_test_wallet_private_key

# Sepolia RPC (Alchemy/Infura/public). Example public endpoint below.
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Optional, for contract verification on Etherscan.
ETHERSCAN_API_KEY=your_etherscan_key
